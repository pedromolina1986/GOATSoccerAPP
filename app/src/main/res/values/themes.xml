<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme for a pure Compose app: AppCompat provides the window,
         Compose's GoatSoccerTheme handles all visual styling. -->
    <style name="Theme.GoatSoccerManager" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorPrimary">@color/green_primary</item>
    </style>
</resources>
